<nav class="site-nav">
    <div class="site-nav__inner">
        <a class="site-nav__brand" href="<%= config.root %>">
            <span class="site-nav__brand-mark">YS</span>
            <span class="site-nav__brand-copy">
                <strong>Yungu Studio</strong>
                <small>Independent developer</small>
            </span>
        </a>

        <button type="button" class="site-nav__toggle" aria-expanded="false" aria-controls="site-nav-links">
            <span class="sr-only">Toggle navigation</span>
            <span></span>
            <span></span>
            <span></span>
        </button>

        <div class="site-nav__links" id="site-nav-links">
            <a href="<%= config.root %>">Home</a>
            <a href="<%= config.root %>products/">Products</a>
            <a href="<%= config.root %>about/">About</a>
            <a href="<%= config.root %>contact/">Contact</a>
            <a href="<%= config.root %>archives/">Articles</a>
        </div>
    </div>
</nav>
<script>
    var navToggle = document.querySelector('.site-nav__toggle');
    var navLinks = document.querySelector('.site-nav__links');

    if (navToggle && navLinks) {
        navToggle.addEventListener('click', function () {
            var isOpen = navLinks.classList.toggle('is-open');
            navToggle.setAttribute('aria-expanded', isOpen ? 'true' : 'false');
        });
    }
</script>
