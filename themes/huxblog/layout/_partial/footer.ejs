<footer class="site-footer">
    <div class="site-footer__inner">
        <div class="site-footer__intro">
            <p class="site-footer__eyebrow">Independent developer</p>
            <h2>Yungu Studio</h2>
            <p>Building practical software for better reading, navigation, and desktop workflows.</p>
        </div>

        <div class="site-footer__grid">
            <div>
                <h3>Products</h3>
                <a href="<%= config.root %>products/#chatgpt-timeline-navigate">ChatGPT Timeline Navigate</a>
                <a href="<%= config.root %>products/#dockdoor">DockDoor</a>
            </div>
            <div>
                <h3>Company</h3>
                <a href="<%= config.root %>about/">About</a>
                <a href="<%= config.root %>contact/">Contact</a>
                <a href="<%= config.root %>archives/">Articles</a>
            </div>
            <div>
                <h3>Legal</h3>
                <a href="<%= config.root %>privacy-policy/">Privacy Policy</a>
                <a href="<%= config.root %>terms-of-service/">Terms of Service</a>
                <a href="<%= config.root %>refund-policy/">Refund Policy</a>
            </div>
            <div>
                <h3>Support</h3>
                <a href="mailto:<%= config.email %>"><%= config.email %></a>
                <% if (config.github_username) { %>
                <a href="https://github.com/<%= config.github_username %>" target="_blank" rel="noopener">GitHub</a>
                <% } %>
            </div>
        </div>

        <div class="site-footer__meta">
            <p>&copy; <%= new Date().getFullYear() %> Yungu Studio. Operated by an independent developer.</p>
        </div>
    </div>
</footer>

<%- js('js/jquery.min.js') %>
<%- js('js/bootstrap.min.js') %>
<%- js('js/hux-blog.min.js') %>
